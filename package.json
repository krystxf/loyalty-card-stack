{
  "name": "wallet-pass",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "next build",
    "check": "tsc --noEmit",
    "biome:ci": "biome ci .",
    "format": "biome check --write --linter-enabled=false .",
    "lint:fix": "biome check --write .",
    "dev": "next dev",
    "start": "next start",
    "prepare": "husky",
    "prisma:generate": "dotenv -e .env.local -- prisma generate",
    "prisma:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "pnpm": {
    "minimumReleaseAge": 10080,
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ],
    "overrides": {
      "effect@<3.20.0": ">=3.20.0"
    },
    "patchedDependencies": {
      "passkit-generator@3.5.7": "patches/passkit-generator@3.5.7.patch"
    }
  },
  "dependencies": {
    "@chakra-ui/react": "^3.35.0",
    "@emotion/react": "^11.14.0",
    "@prisma/client": "^6.16.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@yudiel/react-qr-scanner": "^2.3.1",
    "next": "^15.0.0",
    "next-themes": "^0.4.6",
    "passkit-generator": "^3.5.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^24.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prisma": "^6.16.0",
    "typescript": "^5.9.2"
  }
}
